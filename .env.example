# Path to your Obsidian vault root directory
VAULT_PATH=/path/to/your/vault

# Static bearer token for Claude Code remote access
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_TOKEN=

# HTTP server port (used with --transport http)
PORT=3100

# Default agent name for frontmatter attribution
AGENT_NAME_DEFAULT=claude

# Server URL (used for OAuth metadata endpoints)
# Set to your Tailscale Funnel URL in production
# get your tailscale URL via:
#    tailscale whois $(tailscale ip -4)
SERVER_URL=http://localhost:3100
